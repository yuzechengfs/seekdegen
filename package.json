{
  "name": "seekdegen",
  "version": "0.1.0",
  "private": true,
  "main": "firebase.index.js",
  "description": "Wallet-connected interest matching app prototype.",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "verify": "node scripts/verify-relations.js",
    "reset": "node scripts/reset-dev.js",
    "snapshot": "node scripts/admin-snapshot.js",
    "check": "node --check server.js && node --check app/src/data.js && node --check app/src/render.js && node --check scripts/verify-relations.js",
    "prepare:firebase": "node scripts/prepare-firebase-functions.js",
    "deploy:firebase": "npm run prepare:firebase && firebase deploy --project $FIREBASE_PROJECT_ID --force"
  },
  "dependencies": {
    "firebase-functions": "^6.0.1"
  }
}
